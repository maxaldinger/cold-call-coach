{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cold Call Coach",
  "version": "0.1.0",
  "identifier": "ai.bito.coldcallcoach",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cold Call Coach",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/models/ggml-medium.en.bin": "models/ggml-medium.en.bin",
      "resources/cuda/cudart64_13.dll": "cudart64_13.dll",
      "resources/cuda/cublas64_13.dll": "cublas64_13.dll",
      "resources/cuda/cublasLt64_13.dll": "cublasLt64_13.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/hooks.nsh"
      }
    }
  }
}
